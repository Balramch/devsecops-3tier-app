FROM node:20-alpine

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm ci --only=production

# Copy application code
COPY . .

# 1. Create the group and user
RUN addgroup -S appgroup && adduser -S appuser -G appgroup

# 2. Change ownership (split into its own step)
RUN chown -R appuser:appgroup /app
RUN apk add --no-cache curl
# Security: run as non-root user
USER appuser

EXPOSE 5001

# RELIABLE HEALTHCHECK
HEALTHCHECK --interval=10s --timeout=5s --start-period=15s --retries=5 \
  CMD node -e "require('http').get('http://127.0.0.1:5001/health', (r) => { if (r.statusCode === 200) process.exit(0); else process.exit(1); })" || exit 1

CMD ["node", "index.js"]
